{
	"name": "adaptive-tab-bar-colour",
	"version": "4.0.6",
	"description": "Changes the colour of Firefox theme to match the website’s appearance.",
	"type": "module",
	"scripts": {
		"build": "wxt build -b firefox",
		"format": "prettier --write --list-different src tests",
		"postinstall": "wxt prepare",
		"start": "wxt --mode beta",
		"test": "tsx tests/run.ts",
		"test:headless": "tsx tests/run.ts --headless",
		"zip": "bash scripts/zip.sh",
		"zip:beta": "bash scripts/zip.sh --beta",
		"zip:clean": "bash scripts/zip.sh --clean"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/easonwong-de/Adaptive-Tab-Bar-Colour.git"
	},
	"author": "Eason Wong <me@easonwong.de> (https://easonwong.de/)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/easonwong-de/Adaptive-Tab-Bar-Colour/issues",
		"email": "me@easonwong.de"
	},
	"homepage": "https://github.com/easonwong-de/Adaptive-Tab-Bar-Colour",
	"devDependencies": {
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"@types/selenium-webdriver": "^4.35.6",
		"@wxt-dev/module-react": "^1.2.2",
		"prettier": "^3.8.4",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-jsdoc": "^1.8.1",
		"prettier-plugin-sort-json": "^4.2.0",
		"prettier-plugin-yaml": "^1.2.0",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"web-ext": "^10.4.0",
		"wxt": "^0.20.27"
	},
	"dependencies": {
		"@wxt-dev/i18n": "^0.2.5",
		"clsx": "^2.1.1",
		"geckodriver": "^6.1.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"selenium-webdriver": "^4.45.0",
		"selenium-webext-bridge": "^0.4.0"
	}
}
